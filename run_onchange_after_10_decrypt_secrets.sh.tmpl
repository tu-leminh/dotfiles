#!/bin/bash

# hash: {{ include "dot_secrets.sops.env" | sha256sum }}

export SOPS_AGE_KEY_FILE="${HOME}/.config/sops/age/keys.txt"

if [ -f "${SOPS_AGE_KEY_FILE}" ]; then
  # Decrypt the SOPS encrypted secrets to a local unmanaged file
  sops -d "{{ joinPath .chezmoi.sourceDir "dot_secrets.sops.env" }}" > "${HOME}/.secrets.env"
  chmod 600 "${HOME}/.secrets.env"
  echo "✅ SOPS secrets decrypted to ~/.secrets.env"
else
  echo "⚠️  SOPS age key not found at ${SOPS_AGE_KEY_FILE}. Skipping secrets decryption."
fi